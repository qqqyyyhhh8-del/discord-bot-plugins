  "version": "v0.1.0",
  "description": "Official guild emoji analysis plugin with worldbook updates.",
  "min_host_version": "v0.5.0",
  "runtime": {
    "command": "go",
    "args": ["run", "./cmd/emoji-plugin"]
  },
